{
  "name": "zalisto",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "turbo lint",
    "db:migrate": "pnpm --filter @zalisto/database migrate",
    "import-product": "pnpm --filter @zalisto/cli start"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "overrides": {
      "undici": "^6",
      "drizzle-orm": "0.38.4"
    },
    "peerDependencyRules": {
      "allowAny": ["@opentelemetry/api"]
    }
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "@opentelemetry/api": "^1.9.1"
  }
}
